# auto-certs local secrets — copy to .env y completá los valores.
# Cualquier ${VAR} en configs/config.yaml se resuelve contra este archivo.
# .env está gitignored; .env.example es el template.
#
# En Lambda, los mismos nombres viven en SSM Parameter Store bajo el prefijo
# /auto-certs/$ENV/ y se inyectan al entorno al startup.

# === Cloudflare (no habilitado por ahora) ===
# Token: Zone:Read + DNS:Read para todas las zonas.
CLOUDFLARE_API_TOKEN=

# === Name.com ===
# Generá en https://www.name.com/account/settings/api
# BASE_URL: https://api.dev.name.com (sandbox; user con sufijo -test)
#       o: https://api.name.com (producción)
NAMECOM_USERNAME=
NAMECOM_TOKEN=
NAMECOM_BASE_URL=https://api.dev.name.com

# === SMTP (notifier.backend: smtp) ===
# Solo necesario si vas a probar SMTP real localmente. Para dry-run no aplica.
SMTP_HOST=
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=
SMTP_TO=

# === SES (notifier.backend: ses) ===
# Solo si querés probar SES localmente (necesita credenciales AWS).
# En Lambda viene del SAM template como env vars, no de SSM.
SES_FROM=
SES_TO=

# === AWS ===
# El SDK lee ~/.aws/credentials, env vars, o IAM role automáticamente. Para
# correr `cmd/monitor` localmente con discovery Route53 enabled, exportá:
# AWS_PROFILE=default
# AWS_REGION=us-east-1
