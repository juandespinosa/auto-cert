# auto-certs secrets — copiar a .env y completar los valores.
# Cualquier ${VAR} en configs/config.yaml se resuelve contra este archivo.
# .env está gitignored; .env.example es el template.
#
# Permisos recomendados: chmod 600 .env  (lo hace solo el cron-run.sh
# vía umask 077 para archivos creados en runtime).

# === Cloudflare (no habilitado por ahora) ===
# Token: Zone:Read + DNS:Read para todas las zonas.
CLOUDFLARE_API_TOKEN=

# === Name.com ===
# Generá en https://www.name.com/account/settings/api
# BASE_URL: https://api.dev.name.com (sandbox; user con sufijo -test)
#       o: https://api.name.com (producción)
# Importante: name.com requiere whitelist de IP en el panel de la cuenta.
# La IP pública del server debe estar en "API IP Whitelist".
NAMECOM_USERNAME=
NAMECOM_TOKEN=
NAMECOM_BASE_URL=https://api.name.com

# === SMTP (notifier.backend: smtp) ===
SMTP_HOST=
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=
SMTP_TO=

# === AWS ===
# El SDK lee ~/.aws/credentials, env vars, o IAM role automáticamente. Para
# que el discovery Route53 funcione, exportá (o ponelo en ~/.aws/credentials
# con permisos 600):
# AWS_PROFILE=default
# AWS_REGION=us-east-1
